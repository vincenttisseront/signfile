{
  "extends": "../.nuxt/tsconfig.server.json",
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ESNext"]
  },
  "include": [
    "./**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
