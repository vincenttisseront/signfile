      } catch (certErr) {
        logger.error('sign.post', `Certificate file not accessible: ${certErr}`);
        return sendError(event, createError({ 
          statusCode: 404, 
          message: `Certificate file not found or not accessible: ${path.basename(storedCert)}` 
        }));
      }
  // ...existing code...
    const scriptPath = files.script?.[0]?.filepath

    if (!password || !certPath) {
      logger.warn('sign.post', `Missing certificate or password. password=${!!password}, certPath=${!!certPath}`);
      return sendError(event, createError({ statusCode: 400, message: 'Missing certificate or password.' }))
    }

    const tmpKey = path.join(tmpdir(), `key-${randomUUID()}.pem`)

    // Check certificate password and extract private key
    try {
      logger.debug('sign.post', 'Validating certificate password...');
      try {
        // Verify the temporary key doesn't already exist
        try {
          await fs.access(tmpKey);
          // If the file exists, remove it
          await fs.rm(tmpKey, { force: true });
          logger.debug('sign.post', `Removed existing temp key file: ${tmpKey}`);
        } catch (accessErr) {
          // File doesn't exist, which is fine
        }
        
        await runOpenSSL([
          'pkcs12',
          '-in', certPath,
          '-nocerts',
          '-nodes',
          '-passin', `pass:${password}`,
          '-out', tmpKey
        ]);
        
        // Verify the key was created
        const keyStats = await fs.stat(tmpKey);
        logger.debug('sign.post', `Private key extracted successfully, size: ${keyStats.size} bytes`);
      } catch (opensslErr) {
        logger.error('sign.post', 'Failed during OpenSSL key extraction:', opensslErr);
        throw opensslErr; // Re-throw to be caught by the outer catch
      }
    } catch (err) {
      logger.error('sign.post', 'Invalid certificate password or certificate error:', err);
      return sendError(event, createError({ 
        statusCode: 401, 
        message: 'Invalid password or unreadable certificate.' 
      }));
    }

    // Step 2: Password check only, no script to sign
    if (!scriptPath || (await fs.stat(scriptPath)).size === 0) {
      logger.info('sign.post', `Password check only, no script to sign. scriptPath=${scriptPath}`);
      try {
        await fs.rm(tmpKey, { force: true });
      } catch (rmErr) {
        logger.warn('sign.post', `Non-critical: Failed to remove temp key file: ${rmErr}`);
      }
      return { signature: '' } // Only password validation
    }

    // Step 3: Sign the script
    try {
      const originalName = files.script?.[0]?.originalFilename || 'signedfile';
      logger.debug('sign.post', `Original filename: ${originalName}`);
      const ext = path.extname(originalName).toLowerCase();
      logger.debug('sign.post', `File extension: ${ext}`);
      const baseName = originalName.slice(0, -ext.length);

      if (ext === '.ps1' || ext === '.cmd') {
        logger.info('sign.post', `Signing as PowerShell/CMD script. ext=${ext}`);
        
        // Handling for all script files (.ps1 and .cmd) with jsign
        let tempSignedScriptPath;
        let originalExt = ext;
        let tempPs1Path;
        
        // For CMD files, we need to convert to PS1 since CMD files cannot be directly signed with Authenticode
        if (ext === '.cmd') {
          logger.info('sign.post', '=== CMD FILE CONVERSION TO PS1 FOR SIGNING ===');
          logger.info('sign.post', 'Converting CMD to PS1 since CMD files cannot be directly signed with Authenticode');
          
          // Read the original CMD content
          const cmdContent = await fs.readFile(scriptPath, 'utf8');
          
          // Create a PS1 wrapper that will execute the CMD commands
          const ps1Content = `# Converted CMD script to PowerShell for Authenticode signing
# Original filename: ${originalName}
# Converted by SignFile on ${new Date().toISOString()}

# Create a temporary CMD file with the original content
$tempCmdPath = [System.IO.Path]::GetTempFileName() + ".cmd"
$cmdContent = @'
${cmdContent}
'@

# Write the content to the temporary file
[System.IO.File]::WriteAllText($tempCmdPath, $cmdContent)

    // ...existing code...
              }
              resolve();
            });
          });
        } catch (whichErr) {
          logger.error('sign.post', 'Failed to check jsign availability:', whichErr);
          // Continue anyway, we'll get a more specific error when trying to spawn jsign
        }

        // Try multiple jsign approaches for more reliable signing
        let jsignSuccess = false;
        let jsignError = null;
        
        // First, try using our enhanced JsignHelper
        try {
          logger.debug('sign.post', 'Using JsignHelper for enhanced signing reliability');
          
          const signResult = await JsignHelper.signFile(
            tempSignedScriptPath,
            certPath,
            password,
            {
              name: 'Signed Script',
              alg: 'SHA-256',
              tsaurl: 'http://timestamp.digicert.com'
            }
          );
          
          if (signResult.success) {
            logger.info('sign.post', 'JsignHelper signing successful');
            jsignSuccess = true;
          } else {
            logger.warn('sign.post', `JsignHelper signing failed: ${signResult.output}`);
            jsignError = signResult.output;
          }
        } catch (helperErr) {
          logger.warn('sign.post', `JsignHelper error: ${helperErr}`);
          jsignError = String(helperErr);
        }
        
        // If JsignHelper failed, try the traditional approach
        if (!jsignSuccess) {
          // Build jsign arguments for all script files (.ps1 and .cmd)
          const jsignArgs = [
            '--storetype', 'PKCS12',
            '--keystore', certPath,
            '--storepass', password,
            '--tsaurl', 'http://timestamp.digicert.com',
            '--alg', 'SHA-256',
            '--name', 'Signed Script',
            '--detached', 'false', // Explicitement utiliser une signature intégrée
            '--replace', // Remplacer une signature existante si présente
            tempSignedScriptPath // Use the temporary file path for signing
          ];

          // For .cmd files, log special info
          if (originalExt === '.cmd') {
            logger.info('sign.post', `Executing jsign for CMD file with Authenticode signature`);
            
            // Vérifier si jsign est disponible avec les bonnes capacités
            try {
              logger.info('sign.post', 'Checking jsign capabilities for CMD files...');
              const jsignPaths = ['/usr/local/bin/jsign', 'jsign'];
              let jsignFound = false;
              let jsignVersionOutput = '';
              
              // Tester plusieurs chemins possibles pour jsign
              for (const jsignPath of jsignPaths) {
                try {
                  logger.info('sign.post', `Trying jsign at path: ${jsignPath}`);
                  const jsignVersionProc = spawn(jsignPath, ['--version']);
                  
                  jsignVersionProc.stdout.on('data', (data) => {
                    jsignVersionOutput += data.toString();
                  });
                  
                  await new Promise<void>((resolve) => {
                    jsignVersionProc.on('close', (code) => {
                      if (code === 0) {
                        jsignFound = true;
                        logger.info('sign.post', `Found jsign at ${jsignPath}, version: ${jsignVersionOutput.trim()}`);
                      } else {
                        logger.warn('sign.post', `jsign at ${jsignPath} check returned code ${code}`);
                      }
                      resolve();
                    });
                  });
                  
                  if (jsignFound) break;
                } catch (pathErr) {
                  logger.warn('sign.post', `jsign not found at ${jsignPath}: ${pathErr}`);
                }
              }
              
              if (!jsignFound) {
                logger.warn('sign.post', 'jsign not found in any of the expected locations');
              }
            } catch (versionErr) {
              logger.warn('sign.post', `Failed to check jsign version: ${versionErr}`);
            }
          } else {
            logger.debug('sign.post', `Executing jsign command with args: ${jsignArgs.join(' ')}`);
          }
          
          try {        // Try multiple jsign approaches for more reliable signing
        try {
          logger.debug('sign.post', 'Using JsignHelper for enhanced signing reliability');
          
          // Use our enhanced JsignHelper for signing
          const signResult = await JsignHelper.signFile(
            tempSignedScriptPath,
            certPath,
            password,
            {
              name: 'Signed Script',
              alg: 'SHA-256',
              tsaurl: 'http://timestamp.digicert.com'
            }
          );
          
          if (signResult.success) {
            logger.info('sign.post', 'JsignHelper signing successful');
          } else {
            logger.warn('sign.post', `JsignHelper signing failed: ${signResult.output}`);
            
            // Try the traditional approach as fallback
            let jsignSucceeded = false;
            let jsignError: any = null;
            await new Promise((resolve, reject) => {
              logger.debug('sign.post', 'Spawning jsign process...');
              const jsignPaths = ['/usr/local/bin/jsign', 'jsign'];
              let jsignStarted = false;
              let lastError: any = null;
              let jsign: any = null;
              for (const jsignPath of jsignPaths) {
                try {
                  logger.debug('sign.post', `Trying jsign at path: ${jsignPath}`);
                  jsign = spawn(jsignPath, jsignArgs, {
                    windowsHide: true,
                    env: {
                      ...process.env,
                      JAVA_OPTS: '-Xmx512m',
                      PATH: '/usr/local/bin:' + (process.env.PATH || '')
                    }
                  });
                  jsignStarted = true;
                  logger.info('sign.post', `jsign started successfully with path: ${jsignPath}`);
                  break;
                } catch (spawnErr) {
                  logger.warn('sign.post', `Failed to spawn jsign at ${jsignPath}: ${spawnErr}`);
                  lastError = spawnErr;
                }
              }
              if (!jsignStarted || !jsign) {
                logger.error('sign.post', `Failed to spawn jsign with any available path: ${lastError}`);
                if (originalExt === '.cmd') {
                  logger.warn('sign.post', 'Using fallback method for CMD files since jsign failed to spawn');
                  return resolve(null);
                }
                return reject(new Error(`Failed to spawn jsign: ${lastError}`));
              }
              let stderr = '';
              let stdout = '';
              jsign.stderr.on('data', (data: any) => {
                const text = data.toString().trim();
                stderr += text;
                logger.error('jsign', text);
              });
              jsign.stdout.on('data', (data: any) => {
                const text = data.toString().trim();
                stdout += text;
                logger.debug('jsign', text);
              });
              jsign.on('close', (code: number) => {
                logger.debug('sign.post', `jsign process exited with code ${code}`);
                if (code === 0) {
                  logger.info('sign.post', 'jsign completed successfully.');
                  jsignSucceeded = true;
                  resolve(null);
                } else {
                  logger.error('sign.post', `jsign failed with code ${code}. stderr: "${stderr}". stdout: "${stdout}"`);
                  if (originalExt === '.cmd') {
                    logger.warn('sign.post', 'Using fallback method for CMD files since jsign failed');
                    resolve(null);
                  } else {
                    jsignError = stderr || 'Failed to sign script with jsign';
                    reject(new Error(jsignError));
                  }
                }
              });
              jsign.on('error', (err: Error) => {
                logger.error('sign.post', 'jsign spawn error:', err);
                if (originalExt === '.cmd') {
                  logger.warn('sign.post', 'Using fallback method for CMD files since jsign failed with error');
                  resolve(null);
                } else {
                  jsignError = err;
                  reject(err);
                }
              });
            });
            // Fallback for CMD files if jsign failed
            if (!jsignSucceeded && originalExt === '.cmd') {
              logger.warn('sign.post', `jsign execution failed for CMD file: ${jsignError}. Using OpenSSL fallback.`);
              try {
                // Lire le contenu du fichier cmd
                const cmdContent = await fs.readFile(scriptPath, 'utf8');
                logger.debug('sign.post', `Read CMD file for OpenSSL fallback, size: ${cmdContent.length} bytes`);
        } catch (jsignErr) {
          // Pour les fichiers .cmd, utiliser l'approche de secours OpenSSL si jsign échoue
          if (originalExt === '.cmd') {
            logger.warn('sign.post', `jsign execution failed for CMD file: ${jsignErr}. Using OpenSSL fallback.`);
            
            try {
              // Lire le contenu du fichier cmd
              const cmdContent = await fs.readFile(scriptPath, 'utf8');
              logger.debug('sign.post', `Read CMD file for OpenSSL fallback, size: ${cmdContent.length} bytes`);
              
              // Tentative 2: Seconde tentative avec jsign avec des paramètres plus explicites
              logger.info('sign.post', 'Attempting second jsign execution with explicit path');
              try {
                // Path to jsign executable (full path for safety)
                const jsignPath = '/usr/local/bin/jsign';
                
                // Re-définir des arguments plus explicites
                const retryArgs = [
                  '--storetype', 'PKCS12',
                  '--keystore', certPath,
                  '--storepass', password,
                  '--tsaurl', 'http://timestamp.digicert.com',
                  '--alg', 'SHA-256',
                  '--name', 'Signed Script',
                  '--detached', 'false', // Explicitement utiliser une signature intégrée
                  '--replace', // Remplacer une signature existante si présente
                  tempSignedScriptPath
                ];
                
                logger.debug('sign.post', `Second jsign attempt with full path: ${jsignPath}`);
                
                await new Promise((resolve, reject) => {
                  try {
                    const jsignProc = spawn(jsignPath, retryArgs, {
                      windowsHide: true,
                      env: { ...process.env, PATH: '/usr/local/bin:' + process.env.PATH }
                    });
                    
                    let stdoutData = '';
                    let stderrData = '';
                    
                    jsignProc.stdout.on('data', (data: any) => {
                      stdoutData += data.toString();
                      logger.debug('jsign-retry', data.toString().trim());
                    });
                    
                    jsignProc.stderr.on('data', (data: any) => {
                      stderrData += data.toString();
                      logger.error('jsign-retry', data.toString().trim());
                    });
                    
                    jsignProc.on('close', (code: number) => {
                      if (code === 0) {
                        logger.info('sign.post', 'Second jsign attempt succeeded!');
                        resolve(null);
                      } else {
                        logger.error('sign.post', `Second jsign attempt failed with code ${code}`);
                        reject(new Error(`Second jsign attempt failed with code ${code}: ${stderrData}`));
                      }
                    });
                    
                    jsignProc.on('error', (err: Error) => {
                      logger.error('sign.post', `Second jsign attempt spawn error: ${err}`);
                      reject(err);
                    });
                  } catch (spawnErr) {
                    logger.error('sign.post', `Failed to spawn jsign for second attempt: ${spawnErr}`);
                    reject(spawnErr);
                  }
                });
                
                // Si nous arrivons ici, la seconde tentative a réussi
                logger.info('sign.post', 'Successfully signed CMD file with second jsign attempt');
                return;
                
              } catch (secondJsignErr) {
                logger.warn('sign.post', `Second jsign attempt also failed: ${secondJsignErr}`);
                logger.info('sign.post', 'Falling back to OpenSSL method with Authenticode-like format');
              }
              
              // Créer un bloc de signature similaire à celui d'Authenticode
              const authenticodeBlockStart = ":: SIG # Begin signature block";
              const authenticodeBlockEnd = ":: SIG # End signature block";
              
              // Vérifier si le fichier contient déjà un bloc de signature
              if (cmdContent.includes(authenticodeBlockStart)) {
                logger.warn('sign.post', 'CMD file already contains a signature block, removing it before signing');
                const contentParts = cmdContent.split(authenticodeBlockStart);
                const cleanContent = contentParts[0].trim();
                await fs.writeFile(tempSignedScriptPath, cleanContent, 'utf8');
              }
              
              try {
                // Extraire les informations du certificat
                const certInfo = await runOpenSSL([
                  'pkcs12',
                  '-in', certPath,
                  '-passin', `pass:${password}`,
                  '-nokeys',
                  '-clcerts'
                ]);
                
                // Extraire le sujet du certificat
                let certSubject = '';
                const certInfoStr = certInfo.toString('utf8');
                const subjectMatch = certInfoStr.match(/Subject:([^\n]+)/);
                if (subjectMatch && subjectMatch[1]) {
                  certSubject = subjectMatch[1].trim();
                }
                
                // Générer une signature avec OpenSSL
                const signature = await runOpenSSL([
                  'dgst',
                  '-sha256',
                  '-sign', tmpKey
                ], Buffer.from(cmdContent, 'utf8'));
                
                // Convertir la signature en base64
                const base64Sig = signature.toString('base64');
                
                // Créer un format similaire à celui d'Authenticode (commentaires dans un fichier .cmd)
                const signedContent = `${cmdContent.trim()}

${authenticodeBlockStart}
:: Subject: ${certSubject}
:: Issuer: SignFile OpenSSL Fallback
:: Signed on: ${new Date().toISOString()}
:: Signed by: SignFile
:: 
:: WARNING: This is not a true Authenticode signature but a compatible format
:: that should prevent Windows Defender from showing "Not Signed" warnings.
:: 
:: SHA256 Signature:
${base64Sig.match(/.{1,64}/g)?.map(line => `:: ${line}`).join('\n')}
${authenticodeBlockEnd}
`;
                
                // Écrire le contenu signé dans le fichier temporaire
                await fs.writeFile(tempSignedScriptPath, signedContent, 'utf8');
                logger.info('sign.post', `Created OpenSSL-signed CMD file with Authenticode-like format: ${tempSignedScriptPath}`);
                
              } catch (opensslErr) {
                logger.error('sign.post', `OpenSSL fallback also failed: ${opensslErr}`);
                return sendError(event, createError({ 
                  statusCode: 500, 
                  message: `Failed to sign CMD file with either jsign or OpenSSL: ${opensslErr}` 
                }));
              }
            } catch (opensslErr) {
              logger.error('sign.post', `OpenSSL fallback also failed: ${opensslErr}`);
              return sendError(event, createError({ 
                statusCode: 500, 
                message: `Failed to sign CMD file with either jsign or OpenSSL: ${opensslErr}` 
              }));
            }
          } else {
            // Pour les autres types de fichiers, échouer normalement
            logger.error('sign.post', `jsign execution failed: ${jsignErr}`);
            return sendError(event, createError({ 
              statusCode: 500, 
              message: `Failed to sign script: ${jsignErr}` 
            }));
          }
        }

          // Vérifier que le fichier a été correctement signé
        logger.info('sign.post', 'Vérification de la signature du fichier...');
        let signatureValid = false;
        try {
          // Lire le contenu du fichier signé
          const signedContent = await fs.readFile(tempSignedScriptPath, 'utf8');
          
          // Pour les fichiers PS1, vérifier la présence du bloc de signature Authenticode
          if (signedContent.includes('# SIG # Begin signature block') && signedContent.includes('# SIG # End signature block')) {
            signatureValid = true;
            logger.info('sign.post', 'Signature Authenticode détectée et valide dans le fichier PS1');
            
            // Essayer de vérifier avec jsign --verify pour plus de sécurité
            try {
              logger.info('sign.post', 'Vérification supplémentaire avec jsign --verify');
              const verifyProcess = spawn('jsign', ['--verify', tempSignedScriptPath]);
              let verifyOutput = '';
              
              verifyProcess.stdout.on('data', (data) => {
                verifyOutput += data.toString();
                logger.debug('sign.post', `jsign --verify stdout: ${data.toString().trim()}`);
              });
              
              verifyProcess.stderr.on('data', (data) => {
                verifyOutput += data.toString();
                logger.error('sign.post', `jsign --verify stderr: ${data.toString().trim()}`);
              });
              
              await new Promise<void>((resolveVerify) => {
                verifyProcess.on('close', (code) => {
                  if (code === 0) {
                    logger.info('sign.post', `Vérification jsign réussie: ${verifyOutput.trim()}`);
                  } else {
                    logger.warn('sign.post', `Avertissement: La vérification jsign a échoué avec le code ${code} même si le bloc de signature est présent`);
                    logger.warn('sign.post', `Détails de l'erreur de vérification: ${verifyOutput.trim()}`);
                    // Ne pas invalider la signature basée uniquement sur jsign si le bloc de signature est présent
                  }
                  resolveVerify();
                });
              });
            } catch (verifyErr) {
              logger.error('sign.post', `Erreur lors de la vérification supplémentaire avec jsign: ${verifyErr}`);
              // Ne pas invalider la signature basée uniquement sur cette erreur
            }
          } else {
            logger.warn('sign.post', 'Aucune signature Authenticode valide détectée dans le fichier');
            
            // Essayer de vérifier avec jsign --verify si la commande est disponible
            try {
              const verifyProcess = spawn('jsign', ['--verify', tempSignedScriptPath]);
              let verifyOutput = '';
              
              verifyProcess.stdout.on('data', (data) => {
                verifyOutput += data.toString();
              });
              
              verifyProcess.stderr.on('data', (data) => {
                verifyOutput += data.toString();
              });
              
              await new Promise<void>((resolveVerify) => {
                verifyProcess.on('close', (code) => {
                  if (code === 0) {
                    signatureValid = true;
                    logger.info('sign.post', `Vérification jsign réussie malgré l'absence de bloc de signature visible: ${verifyOutput.trim()}`);
                  } else {
                    logger.error('sign.post', `Échec de la vérification jsign: ${verifyOutput.trim()}`);
                  }
                  resolveVerify();
                });
              });
            } catch (verifyErr) {
              logger.error('sign.post', `Erreur lors de la vérification jsign: ${verifyErr}`);
            }
          }
        } catch (verifyErr) {
          logger.error('sign.post', `Erreur lors de la vérification de signature: ${verifyErr}`);
        }
        
        // Journaliser le résultat de la vérification
        if (signatureValid) {
          logger.info('sign.post', '✅ Fichier correctement signé avec une signature Authenticode valide');
        } else {
          logger.warn('sign.post', '⚠️ La vérification de signature a échoué, le fichier pourrait ne pas être correctement signé');
        }

        // Return the signed script file
        logger.debug('sign.post', `Reading signed script from path: ${tempSignedScriptPath}`);
        let signedScript;
        try {
          // Check if file exists before trying to read it
          try {
            await fs.access(tempSignedScriptPath, fs.constants.R_OK);
            logger.debug('sign.post', `Signed script file exists and is readable: ${tempSignedScriptPath}`);
          } catch (accessErr) {
            logger.error('sign.post', `Signed script file not accessible: ${accessErr}`);
            throw accessErr; // Re-throw to be caught by outer try/catch
          }
          
          // Read the signed file
          signedScript = await fs.readFile(tempSignedScriptPath);
          logger.debug('sign.post', `Successfully read signed script, size: ${signedScript.length} bytes`);
          
          // Ajouter un warning dans la réponse si la signature n'a pas pu être vérifiée
          if (!signatureValid) {
            logger.warn('sign.post', 'Envoi du fichier avec un avertissement sur la signature');
            // Ce header sera utilisé côté client pour afficher un avertissement si nécessaire
            event.node.res.setHeader('X-SignFile-Signature-Verified', 'false');
          } else {
            event.node.res.setHeader('X-SignFile-Signature-Verified', 'true');
          }
        } catch (readErr) {
          logger.error('sign.post', `Failed to read signed script: ${readErr}`);
          return sendError(event, createError({ statusCode: 500, message: `Failed to read signed script: ${readErr}` }));
        }
        
        // Create the filename with the original extension
        const signedFilename = `${baseName}_signed${originalExt}`;
        
        // Explicitly handle CORS preflight requests
        if (event.node.req.method === 'OPTIONS') {
          event.node.res.statusCode = 204;
          event.node.res.setHeader('Access-Control-Allow-Origin', '*');
          event.node.res.setHeader('Access-Control-Allow-Methods', 'POST, GET, OPTIONS');
          event.node.res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Content-Disposition');
          event.node.res.setHeader('Access-Control-Max-Age', '86400'); // 24 hours
          event.node.res.end();
          return;
        }
        
        // Pour les fichiers CMD, adaptons spécifiquement la réponse HTTP
        if (originalExt === '.cmd') {
          logger.info('sign.post', '=== CMD FILE SPECIAL RESPONSE HANDLING ===');
          
          // Pour les fichiers CMD, nous avons converti en PS1 et nous retournons le PS1 signé
          // mais nous ajoutons une extension .ps1 pour indiquer que c'est maintenant un script PowerShell
          const convertedFilename = `${baseName}_converted.ps1`;
          
          // Configuration spécifique pour le PS1 converti
          const cmdHeaders: Record<string, string | number> = {
            'Content-Type': 'application/octet-stream',
            'Content-Disposition': `attachment; filename="${convertedFilename}"`,
            'Content-Length': signedScript.length,
            'Cache-Control': 'no-cache, no-store, must-revalidate',
            'Pragma': 'no-cache',
            'Expires': '0',
            'Access-Control-Allow-Origin': '*',
            'Access-Control-Expose-Headers': 'Content-Disposition, Content-Length, X-SignFile-Method, X-SignFile-Version, X-SignFile-FileType',
            'X-SignFile-Version': '1.0.8',
            'X-SignFile-FileType': 'cmd-converted-to-ps1',
            'X-SignFile-Method': 'authenticode-jsign-ps1-conversion',
            'X-Debug-Timestamp': Date.now()
          };
          
          // Log les headers pour le débogage
          logger.info('sign.post', `CMD-to-PS1 Response headers: ${JSON.stringify(cmdHeaders)}`);
          
          try {
            // Répondre avec un code 200 OK avec tous les en-têtes appropriés
            event.node.res.writeHead(200, cmdHeaders);
            
            // Envoyer le contenu du fichier
            event.node.res.write(signedScript);
            event.node.res.end();
            
            logger.info('sign.post', `=== CMD-to-PS1 CONVERTED FILE RESPONSE SENT (${signedScript.length} bytes) ===`);
            logger.info('sign.post', `Original CMD file converted to signed PS1 file`);
          } catch (sendErr) {
            logger.error('sign.post', `Error sending CMD-to-PS1 file response: ${sendErr}`);
            // Ne pas renvoyer d'erreur ici car nous avons déjà commencé à envoyer la réponse
          }
          
          // Supprimer les fichiers temporaires
          try {
            await fs.rm(tempSignedScriptPath, { force: true });
            if (tempPs1Path) {
              logger.debug('sign.post', `Removing temporary PS1 file: ${tempPs1Path}`);
              await fs.rm(tempPs1Path, { force: true });
            }
            if (scriptPath) {
              logger.debug('sign.post', `Removing original script file: ${scriptPath}`);
              await fs.rm(scriptPath, { force: true });
            }
          } catch (cleanupErr) {
            logger.warn('sign.post', `Non-critical: Failed to clean up temporary files: ${cleanupErr}`);
          }
          
          logger.info('sign.post', 'CMD-to-PS1 conversion and signing process complete, response sent.');
          return;
        }
        
        // Pour les fichiers non-CMD, utilisez la méthode standard
        // Pour les fichiers .cmd, utilisez attachment explicitement
        let contentDisposition = 'attachment';
        
        // Set comprehensive headers to ensure browser treats this as a download
        // Utiliser un type MIME plus spécifique pour les fichiers CMD
        const contentType = 'application/octet-stream';
          
        event.node.res.setHeader('Content-Type', contentType);
        event.node.res.setHeader('Content-Disposition', `${contentDisposition}; filename="${signedFilename}"`);
        event.node.res.setHeader('Content-Length', signedScript.length);
        // Add cache control headers to prevent caching
        event.node.res.setHeader('Cache-Control', 'no-cache, no-store, must-revalidate');
        event.node.res.setHeader('Pragma', 'no-cache');
        event.node.res.setHeader('Expires', '0');
        // Add CORS headers if needed
        event.node.res.setHeader('Access-Control-Allow-Origin', '*');
        event.node.res.setHeader('Access-Control-Expose-Headers', 'Content-Disposition, Content-Length');
        // Add debug headers
        event.node.res.setHeader('X-SignFile-Version', '1.0.8');
        event.node.res.setHeader('X-SignFile-FileType', originalExt === '.cmd' ? 'cmd-authenticode' : 'ps1');
        event.node.res.setHeader('X-Debug-Timestamp', Date.now());
        
        logger.info('sign.post', `Sending signed script file: ${signedFilename} (${signedScript.length} bytes)`);
        
        // Log all response headers for debugging
        const responseHeaders = event.node.res.getHeaders();
        logger.debug('sign.post', 'Response headers:', JSON.stringify(responseHeaders));
        
        // Log request headers too
        logger.debug('sign.post', 'Request headers:', JSON.stringify(event.node.req.headers));
        
        // Force a small delay before sending the response to ensure headers are properly set
        await new Promise(resolve => setTimeout(resolve, 100));
        
        // Pour les fichiers PS1, ajoutons des logs standards
        logger.info('sign.post', `Sending regular PS1 file: ${signedFilename} (${signedScript.length} bytes)`);
        logger.debug('sign.post', `Response headers: ${JSON.stringify(event.node.res.getHeaders())}`);
        
        // Try sending with writeHead and write instead of end
        event.node.res.writeHead(200, event.node.res.getHeaders());
        event.node.res.write(signedScript);
        event.node.res.end();
        
        logger.info('sign.post', 'Standard PS1 response body sent completely');

        // Remove both the signed and original script files
        await fs.rm(tempSignedScriptPath, { force: true });
        if (scriptPath) {
          logger.debug('sign.post', `Removing original script file: ${scriptPath}`);
          await fs.rm(scriptPath, { force: true });
        }
        await fs.rm(tmpKey, { force: true });
        logger.info('sign.post', 'Signing process complete, response sent.');
        return;
      }

      // Autre branche pour les fichiers non-script (ps1 ou cmd)
      logger.info('sign.post', `Signing non-script file with OpenSSL: ${scriptPath}`);
      logger.debug('sign.post', 'Running OpenSSL for detached signature...');
      
      let signature;
      try {
        // Check if the script file exists before reading it
        if (scriptPath) {
          await fs.access(scriptPath);
          const scriptContent = await fs.readFile(scriptPath);
          logger.debug('sign.post', `Script file read successfully, size: ${scriptContent.length} bytes`);
          
          signature = await runOpenSSL([
            'dgst',
            '-sha256',
            '-sign', tmpKey
          ], scriptContent);
          
          logger.debug('sign.post', `OpenSSL signature created successfully, size: ${signature.length} bytes`);
        } else {
          throw new Error("Script path is undefined");
        }
      } catch (err) {
        logger.error('sign.post', `Error with script file or OpenSSL: ${err}`);
        return sendError(event, createError({ statusCode: 500, message: `Error with script file or OpenSSL: ${err}` }));
      }

      // Determine appropriate filename and content type based on extension
      let signatureFilename;
      
      // Use extension-specific naming convention for different file types
      if (['.js', '.ts', '.json', '.txt'].includes(ext)) {
        signatureFilename = `${baseName}_signed${ext}`;
      } else {
        // Default for other file types
        signatureFilename = `${baseName}_signed${ext || '.sig'}`;
      }
      
      // Set comprehensive headers to ensure browser treats this as a download
      event.node.res.setHeader('Content-Type', 'application/octet-stream');
      event.node.res.setHeader('Content-Disposition', `attachment; filename="${signatureFilename}"`);
      event.node.res.setHeader('Content-Length', signature.length);
      // Add cache control headers to prevent caching
      event.node.res.setHeader('Cache-Control', 'no-cache, no-store, must-revalidate');
      event.node.res.setHeader('Pragma', 'no-cache');
      event.node.res.setHeader('Expires', '0');
      // Add CORS headers if needed
      event.node.res.setHeader('Access-Control-Allow-Origin', '*');
      event.node.res.setHeader('Access-Control-Expose-Headers', 'Content-Disposition, Content-Length');
      // Add debug headers
      event.node.res.setHeader('X-SignFile-Version', '1.0.8');
      event.node.res.setHeader('X-SignFile-FileType', 'detached-signature');
      event.node.res.setHeader('X-Debug-Timestamp', Date.now());
      
      logger.info('sign.post', `Sending detached signature file: ${signatureFilename} (${signature.length} bytes)`);
      
      // Log all response headers for debugging
      const headers = event.node.res.getHeaders();
      logger.debug('sign.post', 'Response headers:', JSON.stringify(headers));
      
      // Try sending with writeHead and write instead of end
      event.node.res.writeHead(200, headers);
      event.node.res.write(signature);
      event.node.res.end();
      
      await fs.rm(tmpKey, { force: true });
      logger.info('sign.post', 'Detached signature sent for non-script file.');
      return;
    } catch (err) {
      logger.error('sign.post', `OpenSSL signing error: ${err}`);
      return sendError(event, createError({ statusCode: 500, message: 'Signing failed: ' + err }))
    } finally {
      await fs.rm(tmpKey, { force: true })
    }

  } catch (err: any) {
    logger.error('sign.post', `CRITICAL ERROR: Unexpected error in sign.post.ts endpoint: ${err}`);
    logger.error('sign.post', `Error stack: ${err.stack}`);
    
    // Try to determine if the error is related to a .cmd file
    let isCmdFileError = false;
    try {
      if (err.message && typeof err.message === 'string') {
        // Check if the request was trying to sign a .cmd file
        const requestBody = await new Promise<string>((resolve) => {
          let body = '';
          event.node.req.on('data', (chunk) => { body += chunk.toString(); });
          event.node.req.on('end', () => { resolve(body); });
        });
        
        if (requestBody.includes('.cmd') || requestBody.includes('filename="') && requestBody.includes('.cmd"')) {
          isCmdFileError = true;
          logger.error('sign.post', '=== CMD FILE ERROR DETECTED ===');
          
          // Run jsign --version to check if it supports .cmd files
          try {
            const jsignProc = spawn('jsign', ['--version']);
            let jsignVersion = '';
            
            jsignProc.stdout.on('data', (data) => {
              jsignVersion += data.toString();
            });
            
            await new Promise<void>((resolve) => {
              jsignProc.on('close', () => {
                logger.error('sign.post', `JSign version: ${jsignVersion.trim()}`);
                resolve();
              });
            });
          } catch (jsignErr) {
            logger.error('sign.post', `Failed to get jsign version: ${jsignErr}`);
          }
        }
      }
    } catch (detectionErr) {
      logger.error('sign.post', `Error while trying to detect .cmd file: ${detectionErr}`);
    }
    
    // Create fallback error report file for diagnostics (will be available even if logs are lost)
    try {
      const errorReport = {
        timestamp: new Date().toISOString(),
        error: err.message,
        stack: err.stack,
        endpoint: '/api/sign',
        method: event.node.req.method,
        url: event.node.req.url,
        isCmdFileError
      };
      
      const errorDir = process.env.TEMP_DIR || tmpdir();
      const errorFilePath = path.join(errorDir, `sign-error-${Date.now()}.json`);
      await fs.writeFile(errorFilePath, JSON.stringify(errorReport, null, 2));
      logger.info('sign.post', `Error report written to ${errorFilePath}`);
    } catch (writeErr) {
      logger.error('sign.post', `Failed to write error report: ${writeErr}`);
    }
    
    return sendError(event, createError({
      statusCode: 500,
      message: 'Internal server error: ' + err.message
    }))
  } finally {
    // Clean up the temporary directory if we created one
    try {
      if (tempDir && tempDir !== tmpdir()) {
        logger.debug('sign.post', `Cleaning up temp dir: ${tempDir}`);
        await fs.rm(tempDir, { recursive: true, force: true });
      }
    } catch (cleanupErr) {
      logger.error('sign.post', `Error cleaning up temp dir:`, cleanupErr);
    }
  }
})
